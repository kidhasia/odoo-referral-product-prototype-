# BeaverHub Referral System - Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# Odoo Configuration
VITE_ODOO_BASE_URL=http://localhost:8069
VITE_ODOO_DB=beaverhub_production
VITE_ODOO_SESSION=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_REPORTS=true

# Authentication
VITE_AUTH_TOKEN_KEY=beaverhub_auth_token
VITE_AUTH_USER_KEY=beaverhub_user_data

# Payment Gateway
VITE_STRIPE_KEY=pk_test_xxxxx
VITE_PAYPAL_CLIENT_ID=xxxxx

# Logging
VITE_LOG_LEVEL=info
